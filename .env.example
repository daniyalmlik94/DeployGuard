# Database
POSTGRES_PASSWORD=deployguard

# Encryption key for API keys stored at rest (AES-GCM, must be 32 bytes base64-encoded)
DEPLOYGUARD_ENCRYPTION_KEY=

# JWT signing secret (HS256, at least 32 chars)
DEPLOYGUARD_JWT_SECRET=

# LLM provider keys (optional — mock provider works without these)
GROQ_API_KEY=
OPENROUTER_API_KEY=
