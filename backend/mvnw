# ----------------------------------------------------------------------------
# Apache Maven Wrapper startup batch script, version 3.2.0
# ----------------------------------------------------------------------------

MY_DIR="$(cd "$(dirname "$0")" && pwd)"
MAVEN_PROJECTBASEDIR="${MAVEN_BASEDIR:-$MY_DIR}"
WRAPPERJAR="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar"
WRAPPERPROPERTIES="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.properties"

# Determine the Java executable
if [ -n "$JAVA_HOME" ] ; then
    JAVACMD="$JAVA_HOME/bin/java"
else
    JAVACMD="java"
fi

# Download wrapper jar if not present
if [ ! -e "$WRAPPERJAR" ]; then
    WRAPPER_URL=$(grep wrapperUrl "$WRAPPERPROPERTIES" | cut -d= -f2)
    if command -v curl > /dev/null; then
        curl -fsSL -o "$WRAPPERJAR" "$WRAPPER_URL"
    elif command -v wget > /dev/null; then
        wget -q -O "$WRAPPERJAR" "$WRAPPER_URL"
    else
        echo "ERROR: Neither curl nor wget available to download Maven wrapper." >&2
        exit 1
    fi
fi

exec "$JAVACMD" \
    -classpath "$WRAPPERJAR" \
    "-Dmaven.multiModuleProjectDirectory=$MAVEN_PROJECTBASEDIR" \
    org.apache.maven.wrapper.MavenWrapperMain "$@"
